; ═══════════════════════════════════════════════════════════════
;   SshRemote V2 — Part of NexAgent
;   Configuration File
;   Fill in the values below before running setup_v2.bat
; ═══════════════════════════════════════════════════════════════

[telegram]
; Your Telegram bot token (get it from @BotFather)
bot_token = YOUR_BOT_TOKEN_HERE

; Your Telegram Chat ID (get it from @userinfobot)
chat_id   = YOUR_CHAT_ID_HERE

[install]
; Full installation path (no trailing backslash)
install_path = C:\SshRemote_V2

; Scheduled task name (no spaces)
task_name = SshRemoteTunnel_V2

[bore]
; bore server (default: bore.pub — do not change unless self-hosting)
bore_server = bore.pub

; Local SSH port to tunnel (default: 22)
local_port = 22

[ssh]
; sshd port (default: 22)
sshd_port = 22
